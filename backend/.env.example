# ─────────────────────────────────────────────
# Fantasy League Engine - Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL connection string)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://localhost:5432/fantasy_league

# JWT (use a long random string — never share this)
JWT_SECRET=replace-with-a-very-long-random-string-here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Google Sheets Integration
# Option 1: Service Account JSON (recommended for server-side)
# Paste the entire JSON content of your service account key here (as a single line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option 2: OAuth2 (for user-facing auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
